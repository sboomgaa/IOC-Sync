# ============================================================
# Defender XDR → Check Point IOC Management
# Configuration File (POC mode — inline secrets)
# ============================================================

# ---------- Microsoft Defender XDR (Entra ID app) ----------
azure:
  tenant_id: "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
  client_id: "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
  client_secret: "your-defender-client-secret"

# ---------- Defender API endpoints & runtime ----------
api:
  token_url_template: "https://login.microsoftonline.com/{tenant_id}/oauth2/v2.0/token"
  indicator_url: "https://api.securitycenter.microsoft.com/api/indicators"
  scope: "https://api.securitycenter.microsoft.com/.default"
  request_timeout_seconds: 60
  # Check Point IOC API rate limit is 50 requests/minute per Swagger.
  rate_limit_delay_seconds: 1.2

# ---------- Check Point IOC Management ----------
# Regional endpoints (pick your region):
#   EU:  https://cloudinfra-gw.portal.checkpoint.com
#   AU:  https://cloudinfra-gw.ap.portal.checkpoint.com
#   CA:  https://cloudinfra-gw.ca.portal.checkpoint.com
#   US:  https://cloudinfra-gw.us.portal.checkpoint.com
checkpoint:
  enabled: true
  auth_url: "https://cloudinfra-gw.portal.checkpoint.com"
  api_base_url: "https://cloudinfra-gw.portal.checkpoint.com/app/ioc-management"
  client_id: "your-checkpoint-client-id"
  access_key: "your-checkpoint-access-key"

  feed_name: "MSDefender_Autofeed"

  batch_size: 100
  default_severity: "High"          # "Low"|"Medium"|"High"|"Critical" or 0..100
  default_confidence: "High"        # "Low"|"Medium"|"High"            or 0..100
  expiration_days: 30

  verbose_feeds: true

  supported_types:
    ipv4:   true
    domain: true
    url:    true
    md5:    true
    sha1:   true
    sha256: true

  # -------- Shadow filter --------
  # Check Point silently absorbs certain subdomains into a parent-domain
  # record — confirmed for 'www.' subdomains. When both 'foo.com' and
  # 'www.foo.com' are pushed to the same feed, the 'www.' entry never
  # appears as a separate indicator; CP treats it as covered by 'foo.com'.
  #
  # This filter skips subdomains matching any listed prefix IF the
  # corresponding parent domain is also being sent (in this batch) or is
  # already tracked in state. Other subdomains (mail.foo.com, api.foo.com,
  # etc.) are NOT skipped — they are added independently.
  shadowing:
    enabled: true
    prefixes:
      - "www."

  cleanup:
    enabled: false
    max_delete_per_run: 500

filters:
  exclude_expired: true

output:
  directory: "./exports"
  raw_json_prefix: "defender_threat_indicators_raw"
  csv_prefix: "defender_threat_indicators"
  txt_prefix: "defender_threat_indicators"
  summary_prefix: "run_summary"
  uncreated_prefix: "uncreated_indicators"
  state_file: "cp_ioc_state.json"

logging:
  level: "INFO"
  debug_http: true
