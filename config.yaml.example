# ============================================================
# Defender XDR → Check Point IOC Management
# Configuration File
# ============================================================
# POC MODE: sensitive values are stored inline.
# Recommendations before going to production:
#   - chmod 600 config.yaml
#   - Never commit to source control (.gitignore it)
#   - Migrate secrets to Azure Key Vault or Managed Identity
# ============================================================

# ---------- Microsoft Defender XDR (Entra ID app) ----------
azure:
  tenant_id: "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
  client_id: "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
  client_secret: "your-defender-client-secret"

# ---------- Defender API endpoints & runtime ----------
api:
  token_url_template: "https://login.microsoftonline.com/{tenant_id}/oauth2/v2.0/token"
  indicator_url: "https://api.securitycenter.microsoft.com/api/indicators"
  scope: "https://api.securitycenter.microsoft.com/.default"
  request_timeout_seconds: 60
  rate_limit_delay_seconds: 0.6

# ---------- Check Point IOC Management ----------
checkpoint:
  enabled: true

  # From Check Point Portal → Global Settings → API Keys →
  # service "Centralized IOC Management" -- Customized for the Canada Portal
  auth_url: "https://cloudinfra-gw.ca.portal.checkpoint.com"
  api_base_url: "https://cloudinfra-gw.ca.portal.checkpoint.com/app/ioc-management"
  client_id: "your-checkpoint-client-id"
  access_key: "your-checkpoint-access-key"

  # Manual feed created in the IOC Management portal
  feed_name: "MSDefender_Autofeed"

  # Batching / defaults
  batch_size: 100
  default_severity: "High"        # Low | Medium | High | Critical
  default_confidence: "High"      # Low | Medium | High
  default_action: "Prevent"       # Prevent | Detect
  expiration_days: 30

  # Cleanup: remove IOCs from CP that are no longer in Defender
  cleanup:
    enabled: false                # opt-in
    require_source_match: true    # only delete IOCs sourced from Defender
    max_delete_per_run: 500       # safety cap

# ---------- Filters ----------
filters:
  exclude_expired: true

# ---------- Output ----------
output:
  directory: "./exports"
  raw_json_prefix: "defender_threat_indicators_raw"
  csv_prefix: "defender_threat_indicators"
  txt_prefix: "defender_threat_indicators"
  summary_prefix: "run_summary"

# ---------- Logging ----------
logging:
  level: "INFO"                   # DEBUG | INFO | WARNING | ERROR
  debug_http: true                # include full HTTP error bodies in logs
